---
interface Props {
  projectSlug: string;
  projectTitle: string;
}

const { projectSlug, projectTitle } = Astro.props;
---

<script is:inline define:vars={{ projectSlug, projectTitle }}>
  window.gtag('event', 'project_view', {
    project_slug: projectSlug,
    project_title: projectTitle,
  });
</script>
